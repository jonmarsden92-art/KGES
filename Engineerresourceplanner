                  {getInitials(eng.name)}
                </div>
                <div style={{ flex: 1 }}>
                  <div style={{ fontSize: 14, fontWeight: 600, color: "var(--color-text-primary)" }}>{eng.name}</div>
                  <div style={{ fontSize: 12, color: "var(--color-text-secondary)" }}>{eng.role}</div>
                </div>
                <span style={{ fontSize: 10, padding: "3px 8px", borderRadius: 99, fontWeight: 600, background: isOnJob ? "#fef3c7" : eng.available ? "#dcfce7" : "#fee2e2", color: isOnJob ? "#92400e" : eng.available ? "#166534" : "#991b1b" }}>
                  {isOnJob ? "On Job" : eng.available ? "Available" : "Unavailable"}
                </span>
              </div>
              <div style={{ display: "flex", flexWrap: "wrap", gap: 4, marginBottom: 10 }}>
                {eng.skills.map(s => (
                  <span key={s} style={{ fontSize: 10, background: "var(--color-background-secondary)", color: "var(--color-text-secondary)", borderRadius: 4, padding: "2px 8px", border: "0.5px solid var(--color-border-tertiary)" }}>{s}</span>
                ))}
