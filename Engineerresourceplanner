function ModalWrapper({ title, onClose, children }) {
  return (
    <div style={{ position: "fixed", inset: 0, background: "rgba(0,0,0,0.5)", zIndex: 1000, display: "flex", alignItems: "center", justifyContent: "center" }}>
      <div style={{ background: "var(--color-background-primary)", borderRadius: 14, padding: "28px 32px", width: "90%", maxWidth: 580, maxHeight: "85vh", overflow: "auto", position: "relative" }}>
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 20 }}>
          <h2 style={{ margin: 0, fontSize: 18, fontWeight: 600, color: "var(--color-text-primary)" }}>{title}</h2>
          <button onClick={onClose} style={{ background: "none", border: "none", fontSize: 20, cursor: "pointer", color: "var(--color-text-secondary)" }}>×</button>
        </div>
        {children}
      </div>
    </div>
  );
}

function FieldRow({ label, children }) {
  return (
    <div style={{ marginBottom: 14 }}>
      <label style={{ display: "block", fontSize: 12, fontWeight: 500, color: "var(--color-text-secondary)", marginBottom: 5 }}>{label}</label>
      {children}
    </div>
  );
}

const inputStyle = { width: "100%", padding: "8px 12px", borderRadius: 8, border: "0.5px solid var(--color-border-secondary)", fontSize: 13, background: "var(--color-background-primary)", color: "var(--color-text-primary)", boxSizing: "border-box" };

function JobModal({ job, engineers, onClose, onSave }) {
  const [form, setForm] = useState(job || { title: "", client: "", site: "", date: "", endDate: "", requiredSkills: [], assignedEngineers: [], status: "provisional", priority: "medium" });

  const toggleSkill = (s) => setForm(f => ({ ...f, requiredSkills: f.requiredSkills.includes(s) ? f.requiredSkills.filter(x => x !== s) : [...f.requiredSkills, s] }));
  const toggleEng = (id) => setForm(f => ({ ...f, assignedEngineers: f.assignedEngineers.includes(id) ? f.assignedEngineers.filter(x => x !== id) : [...f.assignedEngineers, id] }));

  const matchingEngineers = form.requiredSkills.length > 0
    ? engineers.filter(e => form.requiredSkills.some(s => e.skills.includes(s)))
    : engineers;

  return (
    <ModalWrapper title={job ? "Edit Job" : "New Job"} onClose={onClose}>
      <FieldRow label="Job Title"><input style={inputStyle} value={form.title} onChange={e => setForm(f => ({ ...f, title: e.target.value }))} placeholder="e.g. HVAC Overhaul" /></FieldRow>
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12 }}>
        <FieldRow label="Client"><input style={inputStyle} value={form.client} onChange={e => setForm(f => ({ ...f, client: e.target.value }))} /></FieldRow>
        <FieldRow label="Site"><input style={inputStyle} value={form.site} onChange={e => setForm(f => ({ ...f, site: e.target.value }))} /></FieldRow>
        <FieldRow label="Start Date"><input type="date" style={inputStyle} value={form.date} onChange={e => setForm(f => ({ ...f, date: e.target.value }))} /></FieldRow>
        <FieldRow label="End Date"><input type="date" style={inputStyle} value={form.endDate} onChange={e => setForm(f => ({ ...f, endDate: e.target.value }))} /></FieldRow>
        <FieldRow label="Status">
          <select style={inputStyle} value={form.status} onChange={e => setForm(f => ({ ...f, status: e.target.value }))}>
            <option value="provisional">Provisional</option>
            <option value="confirmed">Confirmed</option>
            <option value="completed">Completed</option>
          </select>
        </FieldRow>
        <FieldRow label="Priority">
          <select style={inputStyle} value={form.priority} onChange={e => setForm(f => ({ ...f, priority: e.target.value }))}>
            <option value="high">High</option>
            <option value="medium">Medium</option>
            <option value="low">Low</option>
          </select>
        </FieldRow>
      </div>
      <FieldRow label="Required Skills">
        <div style={{ display: "flex", flexWrap: "wrap", gap: 6 }}>
          {SKILLS_LIST.map(s => (
            <button key={s} onClick={() => toggleSkill(s)} style={{ padding: "4px 10px", borderRadius: 99, fontSize: 11, border: "0.5px solid", cursor: "pointer", background: form.requiredSkills.includes(s) ? "#1d4ed8" : "var(--color-background-secondary)", color: form.requiredSkills.includes(s) ? "#fff" : "var(--color-text-secondary)", borderColor: form.requiredSkills.includes(s) ? "#1d4ed8" : "var(--color-border-secondary)" }}>{s}</button>
          ))}
        </div>
      </FieldRow>
      <FieldRow label={`Assign Engineers (${matchingEngineers.length} match required skills)`}>
        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 6, maxHeight: 180, overflow: "auto", padding: "4px 0" }}>
          {matchingEngineers.map(eng => (
            <label key={eng.id} style={{ display: "flex", alignItems: "center", gap: 6, padding: "5px 8px", borderRadius: 6, background: form.assignedEngineers.includes(eng.id) ? "#eff6ff" : "var(--color-background-secondary)", cursor: "pointer", border: "0.5px solid", borderColor: form.assignedEngineers.includes(eng.id) ? "#1d4ed8" : "var(--color-border-tertiary)" }}>
              <input type="checkbox" checked={form.assignedEngineers.includes(eng.id)} onChange={() => toggleEng(eng.id)} style={{ margin: 0 }} />
              <span style={{ fontSize: 12, color: "var(--color-text-primary)" }}>{eng.name}</span>
            </label>
          ))}
        </div>
      </FieldRow>
      <button onClick={() => onSave(form)} style={{ width: "100%", padding: "10px", background: "#1d4ed8", color: "#fff", border: "none", borderRadius: 8, fontSize: 14, fontWeight: 600, cursor: "pointer", marginTop: 6 }}>
        {job ? "Save Changes" : "Create Job"}
      </button>
    </ModalWrapper>
  );
}

function EngineerModal({ engineer, onClose, onSave }) {
  const [form, setForm] = useState(engineer || { name: "", role: "", phone: "", email: "", skills: [], available: true, certExpiry: "", color: "#1d4ed8" });
  const toggleSkill = (s) => setForm(f => ({ ...f, skills: f.skills.includes(s) ? f.skills.filter(x => x !== s) : [...f.skills, s] }));

  return (
    <ModalWrapper title={engineer ? "Edit Engineer" : "Add Engineer"} onClose={onClose}>
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12 }}>
        <FieldRow label="Full Name"><input style={inputStyle} value={form.name} onChange={e => setForm(f => ({ ...f, name: e.target.value }))} /></FieldRow>
        <FieldRow label="Role/Title"><input style={inputStyle} value={form.role} onChange={e => setForm(f => ({ ...f, role: e.target.value }))} /></FieldRow>
        <FieldRow label="Phone"><input style={inputStyle} value={form.phone} onChange={e => setForm(f => ({ ...f, phone: e.target.value }))} /></FieldRow>
        <FieldRow label="Email"><input style={inputStyle} value={form.email} onChange={e => setForm(f => ({ ...f, email: e.target.value }))} /></FieldRow>
        <FieldRow label="Cert Expiry Date"><input type="date" style={inputStyle} value={form.certExpiry} onChange={e => setForm(f => ({ ...f, certExpiry: e.target.value }))} /></FieldRow>
        <FieldRow label="Avatar Color"><input type="color" value={form.color} onChange={e => setForm(f => ({ ...f, color: e.target.value }))} style={{ height: 36, width: "100%", borderRadius: 8, border: "0.5px solid var(--color-border-secondary)", cursor: "pointer" }} /></FieldRow>
      </div>
      <FieldRow label="Availability">
        <label style={{ display: "flex", alignItems: "center", gap: 8, cursor: "pointer", fontSize: 13 }}>
          <input type="checkbox" checked={form.available} onChange={e => setForm(f => ({ ...f, available: e.target.checked }))} />
          Available for jobs
        </label>
      </FieldRow>
      <FieldRow label="Skills">
        <div style={{ display: "flex", flexWrap: "wrap", gap: 6 }}>
          {SKILLS_LIST.map(s => (
            <button key={s} onClick={() => toggleSkill(s)} style={{ padding: "4px 10px", borderRadius: 99, fontSize: 11, border: "0.5px solid", cursor: "pointer", background: form.skills.includes(s) ? "#1d4ed8" : "var(--color-background-secondary)", color: form.skills.includes(s) ? "#fff" : "var(--color-text-secondary)", borderColor: form.skills.includes(s) ? "#1d4ed8" : "var(--color-border-secondary)" }}>{s}</button>
          ))}
        </div>
      </FieldRow>
      <button onClick={() => onSave(form)} style={{ width: "100%", padding: "10px", background: "#1d4ed8", color: "#fff", border: "none", borderRadius: 8, fontSize: 14, fontWeight: 600, cursor: "pointer", marginTop: 6 }}>
        {engineer ? "Save Changes" : "Add Engineer"}
      </button>
    </ModalWrapper>
  );
}

function ReportUploadModal({ onClose, onUpload }) {
  const [file, setFile] = useState(null);
  return (
    <ModalWrapper title="Upload Report" onClose={onClose}>
      <div style={{ border: "2px dashed var(--color-border-secondary)", borderRadius: 10, padding: 32, textAlign: "center", marginBottom: 16 }}>
        <div style={{ fontSize: 32, marginBottom: 8 }}>📁</div>
        <div style={{ fontSize: 14, color: "var(--color-text-secondary)", marginBottom: 12 }}>Drag & drop a PDF report here, or click to browse</div>
        <input type="file" accept=".pdf,.docx,.xlsx" onChange={e => setFile(e.target.files[0])} style={{ fontSize: 13 }} />
      </div>
      <p style={{ fontSize: 12, color: "var(--color-text-secondary)", marginBottom: 16 }}>
        💡 In production, this uploads to Firebase Storage. Connect your Firebase config (see comments at top of file) to enable real file storage and multi-user access.
      </p>
      <button onClick={() => {
        if (!file) return;
        onUpload({ name: file.name, uploadedBy: "Admin", date: new Date().toISOString().split("T")[0], size: (file.size / 1024 / 1024).toFixed(1) + " MB" });
      }} style={{ width: "100%", padding: "10px", background: "#1d4ed8", color: "#fff", border: "none", borderRadius: 8, fontSize: 14, fontWeight: 600, cursor: "pointer" }}>
        Upload
      </button>
    </ModalWrapper>
  );
}
