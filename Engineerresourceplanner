// SKILLS MATRIX
// ============================================================
function SkillsMatrix({ engineers, skillFilter, setSkillFilter, search, setSearch, filteredEngineers }) {
  const toggleSkill = (skill) => {
    setSkillFilter(prev => prev.includes(skill) ? prev.filter(s => s !== skill) : [...prev, skill]);
  };

  return (
    <div>
      <div style={{ background: "var(--color-background-primary)", border: "0.5px solid var(--color-border-tertiary)", borderRadius: 12, padding: 20, marginBottom: 20 }}>
        <h3 style={{ margin: "0 0 12px", fontSize: 14, fontWeight: 600 }}>Filter by Required Skills</h3>
        <p style={{ margin: "0 0 12px", fontSize: 12, color: "var(--color-text-secondary)" }}>Select skills to find engineers who have ALL selected skills</p>
        <div style={{ display: "flex", flexWrap: "wrap", gap: 8, marginBottom: 12 }}>
          {SKILLS_LIST.map(skill => (
            <button key={skill} onClick={() => toggleSkill(skill)} style={{ padding: "5px 12px", borderRadius: 99, fontSize: 12, fontWeight: 500, cursor: "pointer", border: "0.5px solid", transition: "all 0.15s", background: skillFilter.includes(skill) ? "#1d4ed8" : "var(--color-background-secondary)", color: skillFilter.includes(skill) ? "#fff" : "var(--color-text-secondary)", borderColor: skillFilter.includes(skill) ? "#1d4ed8" : "var(--color-border-secondary)" }}>
              {skill}
            </button>
          ))}
        </div>
        <div style={{ display: "flex", gap: 12, alignItems: "center" }}>
          <input value={search} onChange={e => setSearch(e.target.value)} placeholder="Also filter by name..." style={{ padding: "6px 12px", borderRadius: 8, border: "0.5px solid var(--color-border-secondary)", fontSize: 13, background: "var(--color-background-primary)", color: "var(--color-text-primary)", width: 220 }} />
          {(skillFilter.length > 0 || search) && (
            <button onClick={() => { setSkillFilter([]); setSearch(""); }} style={{ fontSize: 12, color: "#dc2626", background: "none", border: "none", cursor: "pointer" }}>Clear filters</button>
          )}
          <span style={{ fontSize: 13, color: "var(--color-text-secondary)", marginLeft: "auto" }}>
            {filteredEngineers.length} engineer{filteredEngineers.length !== 1 ? "s" : ""} match
          </span>
        </div>
      </div>

      {/* Matrix table */}
      <div style={{ background: "var(--color-background-primary)", border: "0.5px solid var(--color-border-tertiary)", borderRadius: 12, overflow: "auto" }}>
        <table style={{ width: "100%", borderCollapse: "collapse", fontSize: 12 }}>
          <thead>
            <tr style={{ background: "var(--color-background-secondary)" }}>
              <th style={{ padding: "10px 16px", textAlign: "left", fontWeight: 600, fontSize: 12, color: "var(--color-text-primary)", borderBottom: "0.5px solid var(--color-border-tertiary)", minWidth: 180, position: "sticky", left: 0, background: "var(--color-background-secondary)" }}>Engineer</th>
              {SKILLS_LIST.map(skill => (
                <th key={skill} style={{ padding: "10px 8px", textAlign: "center", fontWeight: 500, fontSize: 11, color: skillFilter.includes(skill) ? "#1d4ed8" : "var(--color-text-secondary)", borderBottom: "0.5px solid var(--color-border-tertiary)", minWidth: 90, whiteSpace: "nowrap" }}>{skill}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {filteredEngineers.map((eng, i) => (
              <tr key={eng.id} style={{ background: i % 2 === 0 ? "var(--color-background-primary)" : "var(--color-background-secondary)" }}>
                <td style={{ padding: "10px 16px", borderBottom: "0.5px solid var(--color-border-tertiary)", position: "sticky", left: 0, background: i % 2 === 0 ? "var(--color-background-primary)" : "var(--color-background-secondary)" }}>
                  <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
                    <div style={{ width: 26, height: 26, borderRadius: "50%", background: eng.color + "22", display: "flex", alignItems: "center", justifyContent: "center", fontSize: 9, fontWeight: 700, color: eng.color, flexShrink: 0 }}>{getInitials(eng.name)}</div>
                    <div>
                      <div style={{ fontWeight: 500, color: "var(--color-text-primary)" }}>{eng.name}</div>
                      <div style={{ fontSize: 10, color: "var(--color-text-secondary)" }}>{eng.role}</div>
                    </div>
                  </div>
                </td>
                {SKILLS_LIST.map(skill => (
                  <td key={skill} style={{ padding: "10px 8px", textAlign: "center", borderBottom: "0.5px solid var(--color-border-tertiary)" }}>
                    {eng.skills.includes(skill) ? (
                      <span style={{ fontSize: 14, color: skillFilter.includes(skill) ? "#1d4ed8" : "#16a34a" }}>✓</span>
                    ) : (
                      <span style={{ fontSize: 12, color: "var(--color-border-tertiary)" }}>—</span>
                    )}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  );
}

// ============================================================
// JOBS VIEW
// ============================================================
function JobsView({ jobs, engineers, setSelectedJob, setShowJobModal, isAdmin }) {
  const [filter, setFilter] = useState("all");
  const filtered = jobs.filter(j => filter === "all" || j.status === filter || j.priority === filter);

  return (
    <div>
      <div style={{ display: "flex", gap: 8, marginBottom: 16 }}>
        {["all", "confirmed", "provisional", "high", "medium"].map(f => (
          <button key={f} onClick={() => setFilter(f)} style={{ padding: "5px 14px", borderRadius: 99, fontSize: 12, border: "0.5px solid", cursor: "pointer", background: filter === f ? "#1d4ed8" : "var(--color-background-primary)", color: filter === f ? "#fff" : "var(--color-text-secondary)", borderColor: filter === f ? "#1d4ed8" : "var(--color-border-secondary)" }}>
            {f === "all" ? "All Jobs" : f.charAt(0).toUpperCase() + f.slice(1)}
          </button>
        ))}
      </div>
      <div style={{ display: "grid", gap: 12 }}>
        {filtered.map(job => {
          const assignedEngs = job.assignedEngineers.map(id => engineers.find(e => e.id === id)).filter(Boolean);
          const reqCount = job.requiredSkills.length;
          const coveredSkills = job.requiredSkills.filter(skill => assignedEngs.some(e => e.skills.includes(skill)));
          const skillCoverage = Math.round((coveredSkills.length / reqCount) * 100);
          return (
            <div key={job.id} style={{ background: "var(--color-background-primary)", border: "0.5px solid var(--color-border-tertiary)", borderRadius: 12, padding: "18px 22px" }}>
              <div style={{ display: "flex", alignItems: "flex-start", gap: 16, marginBottom: 10 }}>
                <div style={{ flex: 1 }}>
                  <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 4 }}>
                    <h3 style={{ margin: 0, fontSize: 15, fontWeight: 600, color: "var(--color-text-primary)" }}>{job.title}</h3>
                    <span style={{ fontSize: 10, padding: "2px 8px", borderRadius: 99, background: PRIORITY_COLORS[job.priority] + "22", color: PRIORITY_COLORS[job.priority], fontWeight: 600 }}>{job.priority}</span>
                    <span style={{ fontSize: 10, padding: "2px 8px", borderRadius: 99, background: STATUS_COLORS[job.status] + "22", color: STATUS_COLORS[job.status], fontWeight: 600 }}>{job.status}</span>
                  </div>
                  <div style={{ fontSize: 13, color: "var(--color-text-secondary)", marginBottom: 6 }}>{job.client} · {job.site}</div>
                  <div style={{ fontSize: 12, color: "var(--color-text-secondary)" }}>📅 {formatDate(job.date)}{job.endDate !== job.date ? ` – ${formatDate(job.endDate)}` : ""}</div>
                </div>
                {isAdmin && (
                  <button onClick={() => { setSelectedJob(job); setShowJobModal(true); }} style={{ padding: "6px 14px", borderRadius: 6, border: "0.5px solid var(--color-border-secondary)", background: "none", cursor: "pointer", fontSize: 12, color: "var(--color-text-secondary)" }}>
                    Edit
                  </button>
                )}
              </div>
              <div style={{ display: "flex", gap: 16, alignItems: "flex-start", flexWrap: "wrap" }}>
                <div>
                  <div style={{ fontSize: 11, color: "var(--color-text-secondary)", marginBottom: 4 }}>Required Skills</div>
                  <div style={{ display: "flex", gap: 4, flexWrap: "wrap" }}>
                    {job.requiredSkills.map(s => (
                      <span key={s} style={{ fontSize: 10, background: coveredSkills.includes(s) ? "#dcfce7" : "#fee2e2", color: coveredSkills.includes(s) ? "#166534" : "#991b1b", borderRadius: 4, padding: "2px 8px" }}>{s}</span>
                    ))}
                  </div>
                </div>
                <div>
                  <div style={{ fontSize: 11, color: "var(--color-text-secondary)", marginBottom: 4 }}>Assigned Engineers ({assignedEngs.length})</div>
                  <div style={{ display: "flex", gap: 4, flexWrap: "wrap" }}>
                    {assignedEngs.map(eng => (
                      <div key={eng.id} style={{ display: "flex", alignItems: "center", gap: 4, background: eng.color + "15", borderRadius: 99, padding: "2px 8px 2px 4px" }}>
                        <div style={{ width: 18, height: 18, borderRadius: "50%", background: eng.color + "33", display: "flex", alignItems: "center", justifyContent: "center", fontSize: 8, fontWeight: 700, color: eng.color }}>{getInitials(eng.name)}</div>
                        <span style={{ fontSize: 11, color: eng.color, fontWeight: 500 }}>{eng.name.split(" ")[0]}</span>
                      </div>
                    ))}
                  </div>
                </div>
                <div style={{ marginLeft: "auto", textAlign: "right" }}>
                  <div style={{ fontSize: 11, color: "var(--color-text-secondary)", marginBottom: 4 }}>Skill Coverage</div>
                  <div style={{ fontSize: 18, fontWeight: 700, color: skillCoverage === 100 ? "#16a34a" : "#ca8a04" }}>{skillCoverage}%</div>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  );
}

