              {isAdmin && (
                <button onClick={() => { setSelectedEngineer(eng); setShowEngineerModal(true); }} style={{ width: "100%", padding: "6px", borderRadius: 6, border: "0.5px solid var(--color-border-secondary)", background: "none", cursor: "pointer", fontSize: 12, color: "var(--color-text-secondary)" }}>
                  Edit Engineer
