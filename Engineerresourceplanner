// DASHBOARD
// ============================================================
function Dashboard({ engineers, jobs }) {
  const today = new Date().toISOString().split("T")[0];
  const todaysJobs = jobs.filter(j => j.date <= today && j.endDate >= today);
  const busyToday = new Set(todaysJobs.flatMap(j => j.assignedEngineers));
  const availableToday = engineers.filter(e => e.available && !busyToday.has(e.id));
  const expiringSoon = engineers.filter(e => isCertExpiringSoon(e.certExpiry));
  const highPriority = jobs.filter(j => j.priority === "high" && j.status !== "completed");

  const StatCard = ({ label, value, sub, accent }) => (
    <div style={{ background: "var(--color-background-primary)", border: "0.5px solid var(--color-border-tertiary)", borderRadius: 12, padding: "20px 24px", borderLeft: `4px solid ${accent}` }}>
      <div style={{ fontSize: 13, color: "var(--color-text-secondary)", marginBottom: 6 }}>{label}</div>
      <div style={{ fontSize: 32, fontWeight: 700, color: "var(--color-text-primary)", lineHeight: 1 }}>{value}</div>
      {sub && <div style={{ fontSize: 12, color: "var(--color-text-secondary)", marginTop: 6 }}>{sub}</div>}
    </div>
  );

  return (
    <div>
      <div style={{ display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: 16, marginBottom: 28 }}>
        <StatCard label="Total Engineers" value={engineers.length} sub={`${engineers.filter(e => e.available).length} available`} accent="#1d4ed8" />
        <StatCard label="Jobs Today" value={todaysJobs.length} sub={`${highPriority.length} high priority open`} accent="#dc2626" />
        <StatCard label="Available Today" value={availableToday.length} sub="Not on a job today" accent="#16a34a" />
        <StatCard label="Cert Expiring" value={expiringSoon.length} sub="Within 90 days" accent="#ca8a04" />
      </div>

      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 20 }}>
        {/* Today's jobs */}
        <div style={{ background: "var(--color-background-primary)", border: "0.5px solid var(--color-border-tertiary)", borderRadius: 12, padding: "20px 24px" }}>
          <h3 style={{ margin: "0 0 16px", fontSize: 15, fontWeight: 600, color: "var(--color-text-primary)" }}>Today's Active Jobs</h3>
          {todaysJobs.length === 0 && <p style={{ color: "var(--color-text-secondary)", fontSize: 14 }}>No jobs scheduled today</p>}
          {todaysJobs.map(job => (
            <div key={job.id} style={{ display: "flex", alignItems: "center", gap: 12, padding: "10px 0", borderBottom: "0.5px solid var(--color-border-tertiary)" }}>
              <div style={{ width: 10, height: 10, borderRadius: "50%", background: PRIORITY_COLORS[job.priority], flexShrink: 0 }} />
              <div style={{ flex: 1 }}>
                <div style={{ fontSize: 13, fontWeight: 500, color: "var(--color-text-primary)" }}>{job.title}</div>
                <div style={{ fontSize: 12, color: "var(--color-text-secondary)" }}>{job.client} · {job.site}</div>
              </div>
              <span style={{ fontSize: 11, padding: "2px 8px", borderRadius: 99, background: STATUS_COLORS[job.status] + "20", color: STATUS_COLORS[job.status], fontWeight: 500 }}>{job.status}</span>
            </div>
          ))}
        </div>

        {/* Available engineers today */}
        <div style={{ background: "var(--color-background-primary)", border: "0.5px solid var(--color-border-tertiary)", borderRadius: 12, padding: "20px 24px" }}>
          <h3 style={{ margin: "0 0 16px", fontSize: 15, fontWeight: 600, color: "var(--color-text-primary)" }}>Available Engineers Today</h3>
