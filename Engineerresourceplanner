                  <div style={{ fontSize: 10, color: "var(--color-text-secondary)" }}>{eng.skills[0]}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        {/* Cert alerts */}
        <div style={{ background: "var(--color-background-primary)", border: "0.5px solid var(--color-border-tertiary)", borderRadius: 12, padding: "20px 24px" }}>
          <h3 style={{ margin: "0 0 16px", fontSize: 15, fontWeight: 600, color: "var(--color-text-primary)" }}>🟡 Certification Alerts</h3>
          {expiringSoon.map(eng => (
