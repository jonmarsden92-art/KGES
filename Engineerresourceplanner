                </td>
                <td style={{ padding: "14px 20px", fontSize: 13, color: "var(--color-text-secondary)" }}>{r.uploadedBy}</td>
                <td style={{ padding: "14px 20px", fontSize: 13, color: "var(--color-text-secondary)" }}>{r.date}</td>
                <td style={{ padding: "14px 20px", fontSize: 13, color: "var(--color-text-secondary)" }}>{r.size}</td>
                <td style={{ padding: "14px 20px" }}>
                  <button onClick={() => { setReports(prev => prev.filter(x => x.id !== r.id)); showNotif("Report deleted"); }} style={{ fontSize: 12, color: "#dc2626", background: "none", border: "none", cursor: "pointer" }}>Delete</button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  );
}

