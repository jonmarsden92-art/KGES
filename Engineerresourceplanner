              <div style={{ fontSize: 12, color: "#ca8a04", fontWeight: 500 }}>Exp: {formatDate(eng.certExpiry)}</div>
            </div>
          ))}
        </div>

        {/* Quick skills summary */}
        <div style={{ background: "var(--color-background-primary)", border: "0.5px solid var(--color-border-tertiary)", borderRadius: 12, padding: "20px 24px" }}>
          <h3 style={{ margin: "0 0 16px", fontSize: 15, fontWeight: 600, color: "var(--color-text-primary)" }}>Skills Coverage</h3>
          {SKILLS_LIST.slice(0, 8).map(skill => {
            const count = engineers.filter(e => e.skills.includes(skill)).length;
            const pct = Math.round((count / engineers.length) * 100);
            return (
              <div key={skill} style={{ marginBottom: 8 }}>
                <div style={{ display: "flex", justifyContent: "space-between", fontSize: 12, marginBottom: 3 }}>
                  <span style={{ color: "var(--color-text-secondary)" }}>{skill}</span>
                  <span style={{ color: "var(--color-text-primary)", fontWeight: 500 }}>{count} eng</span>
                </div>
                <div style={{ height: 4, background: "var(--color-background-tertiary)", borderRadius: 99 }}>
                  <div style={{ height: 4, width: pct + "%", background: "#1d4ed8", borderRadius: 99 }} />
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  );
}

// ============================================================
// CALENDAR VIEW
// ============================================================
function CalendarView({ engineers, jobs, calMonth, setCalMonth, selectedDate, setSelectedDate, jobsOnDate, busyEngineers }) {
  const { year, month } = calMonth;
  const daysInMonth = getDaysInMonth(year, month);
  const firstDay = new Date(year, month, 1).getDay(); // 0=Sun
  const todayStr = new Date().toISOString().split("T")[0];

  const selectedDateStr = selectedDate instanceof Date ? selectedDate.toISOString().split("T")[0] : null;
  const selectedJobs = selectedDateStr ? jobsOnDate(selectedDateStr) : [];
  const busySet = selectedDateStr ? busyEngineers(selectedDateStr) : new Set();
  const freeEngineers = engineers.filter(e => e.available && !busySet.has(e.id));

  const monthNames = ["January","February","March","April","May","June","July","August","September","October","November","December"];

  return (
    <div style={{ display: "grid", gridTemplateColumns: "1fr 340px", gap: 20 }}>
      {/* Calendar grid */}
      <div style={{ background: "var(--color-background-primary)", border: "0.5px solid var(--color-border-tertiary)", borderRadius: 12, padding: 20 }}>
        <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: 20 }}>
          <button onClick={() => setCalMonth(m => m.month === 0 ? { year: m.year - 1, month: 11 } : { year: m.year, month: m.month - 1 })} style={{ background: "none", border: "0.5px solid var(--color-border-secondary)", borderRadius: 6, padding: "4px 10px", cursor: "pointer", color: "var(--color-text-primary)" }}>←</button>
          <h2 style={{ margin: 0, fontSize: 16, fontWeight: 600 }}>{monthNames[month]} {year}</h2>
          <button onClick={() => setCalMonth(m => m.month === 11 ? { year: m.year + 1, month: 0 } : { year: m.year, month: m.month + 1 })} style={{ background: "none", border: "0.5px solid var(--color-border-secondary)", borderRadius: 6, padding: "4px 10px", cursor: "pointer", color: "var(--color-text-primary)" }}>→</button>
        </div>
        <div style={{ display: "grid", gridTemplateColumns: "repeat(7, 1fr)", gap: 1, textAlign: "center" }}>
          {["Sun","Mon","Tue","Wed","Thu","Fri","Sat"].map(d => (
            <div key={d} style={{ fontSize: 11, fontWeight: 600, color: "var(--color-text-secondary)", padding: "4px 0", letterSpacing: "0.05em" }}>{d}</div>
          ))}
          {Array.from({ length: firstDay === 0 ? 6 : firstDay - 1 }).map((_, i) => <div key={"empty-" + i} />)}
          {Array.from({ length: daysInMonth }).map((_, i) => {
            const dayNum = i + 1;
            const dateStr = `${year}-${String(month + 1).padStart(2, "0")}-${String(dayNum).padStart(2, "0")}`;
            const dayJobs = jobsOnDate(dateStr);
            const isToday = dateStr === todayStr;
            const isSelected = dateStr === selectedDateStr;
            return (
              <div key={dateStr} onClick={() => setSelectedDate(new Date(dateStr + "T12:00:00"))} style={{
                padding: "6px 2px", borderRadius: 6, cursor: "pointer", minHeight: 60,
                background: isSelected ? "#1d4ed8" : isToday ? "#eff6ff" : "transparent",
                border: isToday && !isSelected ? "1.5px solid #1d4ed8" : "1px solid transparent",
                transition: "background 0.1s",
              }}>
                <div style={{ fontSize: 13, fontWeight: isToday ? 700 : 400, color: isSelected ? "#fff" : "var(--color-text-primary)", marginBottom: 2 }}>{dayNum}</div>
                {dayJobs.slice(0, 3).map(j => (
                  <div key={j.id} style={{ fontSize: 9, background: isSelected ? "rgba(255,255,255,0.25)" : PRIORITY_COLORS[j.priority] + "22", color: isSelected ? "#fff" : PRIORITY_COLORS[j.priority], borderRadius: 3, padding: "1px 3px", marginBottom: 1, overflow: "hidden", whiteSpace: "nowrap", textOverflow: "ellipsis" }}>
                    {j.title}
                  </div>
                ))}
                {dayJobs.length > 3 && <div style={{ fontSize: 9, color: isSelected ? "#bfdbfe" : "var(--color-text-secondary)" }}>+{dayJobs.length - 3} more</div>}
              </div>
            );
          })}
        </div>
      </div>

      {/* Selected day panel */}
      <div>
        {selectedDateStr && (
          <>
            <div style={{ background: "var(--color-background-primary)", border: "0.5px solid var(--color-border-tertiary)", borderRadius: 12, padding: 18, marginBottom: 16 }}>
              <h3 style={{ margin: "0 0 12px", fontSize: 14, fontWeight: 600 }}>{formatDate(selectedDateStr)} — Jobs ({selectedJobs.length})</h3>
              {selectedJobs.length === 0 && <p style={{ fontSize: 13, color: "var(--color-text-secondary)", margin: 0 }}>No jobs on this day</p>}
              {selectedJobs.map(job => (
                <div key={job.id} style={{ background: "var(--color-background-secondary)", borderRadius: 8, padding: "10px 12px", marginBottom: 8 }}>
                  <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 4 }}>
                    <div style={{ fontSize: 13, fontWeight: 600, color: "var(--color-text-primary)" }}>{job.title}</div>
                    <span style={{ fontSize: 10, padding: "2px 6px", borderRadius: 99, background: PRIORITY_COLORS[job.priority] + "22", color: PRIORITY_COLORS[job.priority], fontWeight: 600, flexShrink: 0 }}>{job.priority}</span>
                  </div>
                  <div style={{ fontSize: 12, color: "var(--color-text-secondary)", marginBottom: 6 }}>{job.client} · {job.site}</div>
                  <div style={{ display: "flex", gap: 4, flexWrap: "wrap" }}>
                    {job.assignedEngineers.map(eid => {
                      const eng = SAMPLE_ENGINEERS.find(e => e.id === eid);
                      return eng ? (
                        <div key={eid} style={{ fontSize: 10, background: eng.color + "22", color: eng.color, borderRadius: 99, padding: "2px 8px", fontWeight: 500 }}>
                          {eng.name.split(" ")[0]}
                        </div>
                      ) : null;
                    })}
                  </div>
                </div>
              ))}
            </div>

            <div style={{ background: "var(--color-background-primary)", border: "0.5px solid var(--color-border-tertiary)", borderRadius: 12, padding: 18 }}>
              <h3 style={{ margin: "0 0 12px", fontSize: 14, fontWeight: 600, color: "#16a34a" }}>✓ Free Engineers ({freeEngineers.length})</h3>
              {freeEngineers.map(eng => (
                <div key={eng.id} style={{ display: "flex", alignItems: "center", gap: 8, padding: "6px 0", borderBottom: "0.5px solid var(--color-border-tertiary)" }}>
                  <div style={{ width: 28, height: 28, borderRadius: "50%", background: eng.color + "22", display: "flex", alignItems: "center", justifyContent: "center", fontSize: 10, fontWeight: 700, color: eng.color, flexShrink: 0 }}>{getInitials(eng.name)}</div>
                  <div>
                    <div style={{ fontSize: 12, fontWeight: 500, color: "var(--color-text-primary)" }}>{eng.name}</div>
                    <div style={{ fontSize: 10, color: "var(--color-text-secondary)" }}>{eng.skills.slice(0, 2).join(" · ")}</div>
                  </div>
                </div>
              ))}
            </div>
          </>
        )}
        {!selectedDateStr && (
          <div style={{ background: "var(--color-background-primary)", border: "0.5px solid var(--color-border-tertiary)", borderRadius: 12, padding: 18, textAlign: "center", color: "var(--color-text-secondary)", fontSize: 14 }}>
            Select a day to see jobs and available engineers
          </div>
        )}
      </div>
    </div>
  );
}

